{
  "name": "nexaflow-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-expo-local.ps1",
    "android": "expo run:android",
    "eas:login": "powershell -NoProfile -ExecutionPolicy Bypass -File ./eas-local.ps1 login",
    "eas:whoami": "powershell -NoProfile -ExecutionPolicy Bypass -File ./eas-local.ps1 whoami",
    "build:android": "eas build -p android --profile preview",
    "build:android:localenv": "powershell -NoProfile -ExecutionPolicy Bypass -File ./eas-local.ps1 build -p android --profile preview",
    "build:android:private": "powershell -NoProfile -ExecutionPolicy Bypass -File ./build-private-apk.ps1",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo/vector-icons": "14.1.0",
    "expo": "~51.0.0",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-screen-orientation": "~7.0.5",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "graphql": "^15.8.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-safe-area-context": "4.10.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
